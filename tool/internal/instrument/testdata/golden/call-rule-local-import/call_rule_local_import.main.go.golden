package main

import (
	"unsafe"

	"github.com/open-telemetry/opentelemetry-go-compile-instrumentation/tool/internal/instrument/testhelper/wrapper"
)

func CallSizeof() {
	x := 42
	size := wrapper.Sizeof(unsafe.Sizeof(x))
	_ = size
}

func main() {
	y := "hello"
	_ = wrapper.Sizeof(unsafe.Sizeof(y))
}
