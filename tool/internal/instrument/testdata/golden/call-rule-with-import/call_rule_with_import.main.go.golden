package main

import (
	"unsafe"

	"fmt"
)

func CallSizeof() {
	x := 42
	size := (func() uintptr { fmt.Println("Wrapped!"); return unsafe.Sizeof(x) })()
	_ = size
}

func main() {
	y := "hello"
	_ = (func() uintptr { fmt.Println("Wrapped!"); return unsafe.Sizeof(y) })()
}
