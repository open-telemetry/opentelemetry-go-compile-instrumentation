package main

import (
	"unsafe"

	"github.com/open-telemetry/opentelemetry-go-compile-instrumentation/tool/internal/instrument/testdata/golden/call-rule-external-wrapper/helpers/wrapper"
)

func CallSizeof() {
	x := 42
	size := wrapper.Wrapper(unsafe.Sizeof(x))
	_ = size
}

func main() {
	y := "hello"
	_ = wrapper.Wrapper(unsafe.Sizeof(y))
}
